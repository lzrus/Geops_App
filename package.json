{
  "name": "geops",
  "private": true,
  "version": "1.0.0",
  "description": "Système de gestion complet pour boucherie",
  "author": "GEOPS",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-server server.js prisma/dev.db prisma/dev.db-journal",
    "lint": "tsc --noEmit",
    "electron": "electron .",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "server": "tsx server.ts",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --outfile=dist-server/server.js --external:express --external:cors --external:bcryptjs --external:jsonwebtoken --external:@prisma/client --external:cookie-parser --external:dotenv",
    "prisma:generate:sqlite": "prisma generate --schema prisma/schema.sqlite.prisma",
    "prisma:generate:mysql": "prisma generate --schema prisma/schema.prisma",
    "prisma:db:push:sqlite": "cross-env DATABASE_URL=file:./prisma/dev.db prisma db push --schema prisma/schema.sqlite.prisma",
    "electron:build:all": "npm run prisma:generate:sqlite && npm run prisma:db:push:sqlite && cross-env DATABASE_URL=file:./prisma/dev.db node create-admin.cjs && npm run build && npm run build:server && electron-builder && npm run prisma:generate:mysql"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@prisma/client": "^6.2.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "mysql2": "^3.11.5",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "vite": "^6.2.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.25.0",
    "prisma": "^6.2.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "prisma@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.0": true,
    "protobufjs@7.6.2": true,
    "@google/genai@2.7.0": true
  }
}
